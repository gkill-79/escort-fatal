// escorte-fatal — Prisma Schema
// PostgreSQL 18

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────

enum UserRole {
  MEMBER
  ESCORT
  ADMIN
}

enum ProfileGender {
  FEMALE
  MALE
  TRANS
  COUPLE
}

enum ServiceType {
  GFE
  BDSM
  WEBCAM
  MASSAGE
  DOMINATION
  OUTCALL
  INCALL
  VIRTUAL
  ESCORT
  FETISH
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentProduct {
  BOOST_7D
  BOOST_30D
  TOP_GIRL_7D
  TOP_GIRL_30D
  CHAT_CREDITS_10
  CHAT_CREDITS_50
  CREDIT_PACK_100
  CREDIT_PACK_300
  EXCLUSIVE_30D
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum ReportReason {
  FAKE_PROFILE
  UNDERAGE
  SPAM
  SCAM
  INAPPROPRIATE
  OTHER
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

// ─── Tables ───────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  username         String    @unique
  passwordHash     String
  role             UserRole  @default(MEMBER)
  avatarUrl        String?
  isActive         Boolean   @default(true)
  isEmailVerified  Boolean   @default(false)
  emailVerifyToken String?
  resetToken       String?
  resetTokenExpiresAt DateTime?
  chatCredits      Int       @default(0)
  credits          Int       @default(0)
  lastSeenAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  profile             Profile?
  sentMessages        Message[]            @relation("MessageSender")
  chatRooms           ChatRoom[]           @relation("MemberRooms")
  photoRatings        PhotoRating[]
  comments            Comment[]
  follows             Follow[]             @relation("Follower")
  payments            Payment[]
  reports             Report[]             @relation("Reporter")
  passwordResetTokens PasswordResetToken[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@map("users")
}

model Country {
  id       Int     @id @default(autoincrement())
  name     String
  code     String  @unique  // FR, BE, LU
  flagUrl  String?
  isActive Boolean @default(true)

  departments Department[]
  cities      City[]

  @@map("countries")
}

model Department {
  id           Int     @id @default(autoincrement())
  name         String
  slug         String  @unique
  code         String  // 75, 13, etc.
  region       String?
  countryId    Int
  profileCount Int     @default(0)

  country   Country   @relation(fields: [countryId], references: [id])
  cities    City[]
  profiles  Profile[]

  @@index([countryId])
  @@map("departments")
}

model City {
  id           Int     @id @default(autoincrement())
  name         String
  slug         String  @unique
  departmentId Int?
  countryId    Int
  lat          Float?
  lon          Float?
  profileCount Int     @default(0)
  isPopular    Boolean @default(false)

  department   Department?    @relation(fields: [departmentId], references: [id])
  country      Country        @relation(fields: [countryId], references: [id])
  profiles     Profile[]
  cityTours    CityTour[]
  announcements Announcement[]

  @@index([slug])
  @@index([countryId])
  @@index([isPopular])
  @@map("cities")
}

model Profile {
  id             String        @id @default(cuid())
  userId         String        @unique
  slug           String        @unique
  name           String
  age            Int?
  gender         ProfileGender @default(FEMALE)
  bio            String?
  phoneEncrypted String?       // AES-256 encrypted
  whatsapp       String?
  cityId         Int?
  departmentId   Int?

  // Status
  isOnline     Boolean   @default(false)
  lastOnlineAt DateTime?
  isVerified   Boolean   @default(false)
  isExclusive  Boolean   @default(false)
  isTopGirl    Boolean   @default(false)
  topGirlUntil DateTime?
  boostScore   Int       @default(0)
  boostUntil   DateTime?
  isApproved   Boolean   @default(false)
  isActive     Boolean   @default(true)
  acceptsChat  Boolean   @default(true)

  // Stats
  viewCount     Int   @default(0)
  followerCount Int   @default(0)
  ratingAvg     Float @default(0)
  ratingCount   Int   @default(0)

  // Pricing
  priceFrom Int? // EUR
  priceTo   Int?

  // Profile details
  height      Int?     // cm
  weight      Int?     // kg
  bust        Int?     // cm
  nationality String?
  languages   String[] @default([])
  hairColor   String?
  eyeColor    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  city         City?            @relation(fields: [cityId], references: [id])
  department   Department?      @relation(fields: [departmentId], references: [id])
  photos       ProfilePhoto[]
  videos       ProfileVideo[]
  services     ProfileService[]
  comments     Comment[]
  followers    Follow[]         @relation("FollowedProfile")
  cityTours    CityTour[]
  chatRooms    ChatRoom[]       @relation("EscorteRooms")
  payments     Payment[]
  reports      Report[]         @relation("ReportedProfile")
  availability Availability[]

  @@index([slug])
  @@index([cityId])
  @@index([departmentId])
  @@index([gender])
  @@index([isOnline])
  @@index([isTopGirl])
  @@index([isApproved, isActive])
  @@index([boostScore(sort: Desc)])
  @@map("profiles")
}

model ProfilePhoto {
  id           String   @id @default(cuid())
  profileId    String
  url          String
  thumbnailUrl String?
  blurUrl      String?
  isPrimary    Boolean  @default(false)
  isApproved   Boolean  @default(false)
  isPremium    Boolean  @default(false)
  unlockPriceCredits Int?
  order        Int      @default(0)
  ratingAvg    Float    @default(0)
  ratingCount  Int      @default(0)
  width        Int?
  height       Int?
  sizeBytes    Int?
  createdAt    DateTime @default(now())

  profile Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  ratings PhotoRating[]

  @@index([profileId])
  @@index([isPrimary])
  @@index([ratingAvg(sort: Desc)])
  @@map("profile_photos")
}

model ProfileVideo {
  id           String   @id @default(cuid())
  profileId    String
  urlHls       String?
  urlMp4       String
  thumbnailUrl String?
  duration     Int?     // seconds
  isApproved   Boolean  @default(false)
  viewCount    Int      @default(0)
  createdAt    DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("profile_videos")
}

model ProfileService {
  id          String      @id @default(cuid())
  profileId   String
  type        ServiceType
  description String?
  price       Int?        // EUR

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, type])
  @@map("profile_services")
}

model Follow {
  followerId String
  profileId  String
  createdAt  DateTime @default(now())

  follower User    @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  profile  Profile @relation("FollowedProfile", fields: [profileId], references: [id], onDelete: Cascade)

  @@id([followerId, profileId])
  @@index([profileId])
  @@map("follows")
}

model Comment {
  id         String   @id @default(cuid())
  authorId   String
  profileId  String
  content    String
  rating     Int?     // 1-5
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([authorId])
  @@index([isApproved])
  @@map("comments")
}

model PhotoRating {
  id        String   @id @default(cuid())
  userId    String
  photoId   String
  score     Int      // 1-5
  createdAt DateTime @default(now())

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo ProfilePhoto @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([userId, photoId])
  @@index([photoId])
  @@map("photo_ratings")
}

model ChatRoom {
  id            String    @id @default(cuid())
  profileId     String
  memberId      String
  isActive      Boolean   @default(true)
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())

  profile  Profile   @relation("EscorteRooms", fields: [profileId], references: [id], onDelete: Cascade)
  member   User      @relation("MemberRooms",  fields: [memberId],  references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([profileId, memberId])
  @@index([profileId])
  @@index([memberId])
  @@map("chat_rooms")
}

model Message {
  id               String      @id @default(cuid())
  roomId           String
  senderId         String
  contentEncrypted String      // AES encrypted
  type             MessageType @default(TEXT)
  sentAt           DateTime    @default(now())
  readAt           DateTime?

  room   ChatRoom @relation(fields: [roomId],   references: [id], onDelete: Cascade)
  sender User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([senderId])
  @@index([sentAt])
  @@map("messages")
}

model Announcement {
  id        String   @id @default(cuid())
  authorId  String
  title     String
  content   String
  cityId    Int?
  category  String?
  views     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city City? @relation(fields: [cityId], references: [id])

  @@index([cityId])
  @@index([createdAt(sort: Desc)])
  @@map("announcements")
}

model Payment {
  id              String         @id @default(cuid())
  userId          String
  profileId       String?
  stripeSessionId String?        @unique
  stripePaymentId String?
  amount          Int            // centimes
  currency        String         @default("eur")
  product         PaymentProduct
  status          PaymentStatus  @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user    User     @relation(fields: [userId],   references: [id])
  profile Profile? @relation(fields: [profileId], references: [id])

  @@index([userId])
  @@index([profileId])
  @@index([status])
  @@map("payments")
}

model CityTour {
  id          String   @id @default(cuid())
  profileId   String
  cityId      Int
  dateFrom    DateTime
  dateTo      DateTime
  description String?
  createdAt   DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  city    City    @relation(fields: [cityId],    references: [id])

  @@index([profileId])
  @@index([cityId])
  @@index([dateFrom])
  @@map("city_tours")
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  profileId  String
  reason     ReportReason
  details    String?
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  reporter User    @relation("Reporter",        fields: [reporterId], references: [id], onDelete: Cascade)
  profile  Profile @relation("ReportedProfile", fields: [profileId],  references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([status])
  @@map("reports")
}

model Availability {
  id        String   @id @default(cuid())
  profileId String
  dayOfWeek Int      // 0=Sun, 6=Sat
  startHour Int      // 0-23
  endHour   Int      // 0-23

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("availability")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}