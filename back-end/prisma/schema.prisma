// escorte-fatal — Prisma Schema
// PostgreSQL 18

generator client {
  provider = "prisma-client-js"
}

generator client_frontend {
  provider = "prisma-client-js"
  output   = "../../front-end/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────

enum Role {
  USER
  ESCORT
  ADMIN
}

enum ProfileStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum ProfileGender {
  FEMALE
  MALE
  TRANS
  COUPLE
}

enum ServiceType {
  GFE
  BDSM
  WEBCAM
  MASSAGE
  DOMINATION
  OUTCALL
  INCALL
  VIRTUAL
  ESCORT
  FETISH
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentProduct {
  BOOST_7D
  BOOST_30D
  TOP_GIRL_7D
  TOP_GIRL_30D
  CHAT_CREDITS_10
  CHAT_CREDITS_50
  CREDIT_PACK_100
  CREDIT_PACK_300
  EXCLUSIVE_30D
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

// ─── Tables ───────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  username         String    @unique
  passwordHash     String
  role             Role      @default(USER)
  avatarUrl        String?
  isActive         Boolean   @default(true)
  isEmailVerified  Boolean   @default(false)
  emailVerifyToken String?
  resetToken       String?
  resetTokenExpiresAt DateTime?
  chatCredits      Int       @default(0)
  credits          Int       @default(0)
  creditsBalance   Int       @default(0) // Virtual wallet for monetization
  lastSeenAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  profile             Profile?
  sentMessages        Message[]            @relation("MessageSender")
  chatRooms           ChatRoom[]           
  photoRatings        PhotoRating[]
  comments            Comment[]
  follows             Follow[]             @relation("Follower")
  payments            Payment[]
  unlockedMedia       UnlockedMedia[]
  filedReports        Report[]             @relation("FiledReports")
  transactions        Transaction[]
  creditLogs          CreditLog[]          @relation("UserCreditLogs")
  messages            Message[]            @relation("UserMessages")
  passwordResetTokens PasswordResetToken[]
  kycRecord           KycRecord?
  orders              Order[]              @relation("UserOrders")
  
  // Appels Vidéos P2P
  clientCalls         CallSession[]        @relation("ClientCalls")
  escortCalls         CallSession[]        @relation("EscortCalls")

  @@index([email])
  @@index([username])
  @@map("users")
}

model Country {
  id       Int     @id @default(autoincrement())
  name     String
  code     String  @unique  // FR, BE, LU
  flagUrl  String?
  isActive Boolean @default(true)

  departments Department[]
  cities      City[]

  @@map("countries")
}

model Department {
  id           Int     @id @default(autoincrement())
  name         String
  slug         String  @unique
  code         String  // 75, 13, etc.
  region       String?
  countryId    Int
  profileCount Int     @default(0)

  country   Country   @relation(fields: [countryId], references: [id])
  cities    City[]
  profiles  Profile[]

  @@index([countryId])
  @@map("departments")
}

model City {
  id           Int     @id @default(autoincrement())
  name         String
  slug         String  @unique
  departmentId Int?
  countryId    Int
  lat          Float?
  lon          Float?
  profileCount Int     @default(0)
  isPopular    Boolean @default(false)

  department   Department?    @relation(fields: [departmentId], references: [id])
  country      Country        @relation(fields: [countryId], references: [id])
  profiles     Profile[]
  cityTours    CityTour[]
  announcements Announcement[]

  @@index([slug])
  @@index([countryId])
  @@index([isPopular])
  @@map("cities")
}

model Profile {
  id             String        @id @default(cuid())
  userId         String        @unique
  slug           String        @unique
  name           String
  age            Int?
  gender         ProfileGender @default(FEMALE)
  bio            String?
  phoneEncrypted String?       // AES-256 encrypted
  whatsapp       String?
  cityId         Int?
  departmentId   Int?
  latitude       Float?
  longitude      Float?

  // Facturation des services virtuels
  videoCallPricePerMin Int @default(50) // ex: 50 crédits la minute

  // Status
  isOnline     Boolean   @default(false)
  lastOnlineAt DateTime?
  isVerified   Boolean   @default(false)
  
  // KYC Biométrique IDNow/IDCheck.io
  kycStatus         KycStatus @default(NONE)
  biometricVerified Boolean   @default(false)
  kycReference      String?
  kycUpdatedAt      DateTime?
  
  isExclusive  Boolean   @default(false)
  isTopGirl    Boolean   @default(false)
  topGirlUntil DateTime?
  baseScore    Float     @default(1.0) // Organic quality score
  boostScore   Float     @default(1.0) // Paid multiplier
  boostExpires DateTime? // When the boost ends
  isApproved   Boolean   @default(false)
  isActive     Boolean   @default(true)
  acceptsChat  Boolean   @default(true)
  status       ProfileStatus @default(PENDING)

  // Métriques pour l'Algorithme de Ranking Dynamique
  lastActivityAt      DateTime @default(now()) // Mis à jour à chaque connexion/action
  calendarUpdatedAt   DateTime @default(now()) // Mis à jour quand l'escorte modifie ses dispos
  averageResponseTime Int      @default(60)    // En minutes (calculé par le module de chat)
  activityScore       Int      @default(0)     // Le score global calculé par notre algorithme (0-200)

  // Stats
  viewCount     Int   @default(0)
  followerCount Int   @default(0)
  ratingAvg     Float @default(0)
  ratingCount   Int   @default(0)

  // Pricing
  priceFrom Int? // EUR
  priceTo   Int?

  // Profile details
  height      Int?     // cm
  weight      Int?     // kg
  bust        Int?     // cm
  nationality String?
  languages   String[] @default([])
  categories  String[] @default([])
  hairColor   String?
  eyeColor    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  city            City?            @relation(fields: [cityId], references: [id])
  department      Department?      @relation(fields: [departmentId], references: [id])
  photos          ProfilePhoto[]
  videos          ProfileVideo[]
  services        ProfileService[]
  comments        Comment[]
  followers       Follow[]         @relation("FollowedProfile")
  cityTours       CityTour[]
  payments        Payment[]
  availability    Availability[]
  media           Media[]
  receivedReports Report[]         @relation("ReceivedReports")
  mediaAssets     MediaAsset[]

  @@index([slug])
  @@index([cityId])
  @@index([departmentId])
  @@index([gender])
  @@index([isOnline])
  @@index([isTopGirl])
  @@index([isApproved, isActive])
  @@index([activityScore(sort: Desc)])
  @@index([boostScore(sort: Desc)])
  @@map("profiles")
}

model ProfilePhoto {
  id           String   @id @default(cuid())
  profileId    String
  url          String
  thumbnailUrl String?
  blurUrl      String?
  isPrimary    Boolean  @default(false)
  isApproved   Boolean  @default(false)
  isPremium    Boolean  @default(false)
  unlockPriceCredits Int?
  order        Int      @default(0)
  ratingAvg    Float    @default(0)
  ratingCount  Int      @default(0)
  width        Int?
  height       Int?
  sizeBytes    Int?
  createdAt    DateTime @default(now())

  profile Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  ratings PhotoRating[]

  @@index([profileId])
  @@index([isPrimary])
  @@index([ratingAvg(sort: Desc)])
  @@map("profile_photos")
}

model ProfileVideo {
  id           String   @id @default(cuid())
  profileId    String
  urlHls       String?
  urlMp4       String
  thumbnailUrl String?
  duration     Int?     // seconds
  isApproved   Boolean  @default(false)
  viewCount    Int      @default(0)
  createdAt    DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("profile_videos")
}

model ProfileService {
  id          String      @id @default(cuid())
  profileId   String
  type        ServiceType
  description String?
  price       Int?        // EUR

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, type])
  @@map("profile_services")
}

model Follow {
  followerId String
  profileId  String
  createdAt  DateTime @default(now())

  follower User    @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  profile  Profile @relation("FollowedProfile", fields: [profileId], references: [id], onDelete: Cascade)

  @@id([followerId, profileId])
  @@index([profileId])
  @@map("follows")
}

model Comment {
  id         String   @id @default(cuid())
  authorId   String
  profileId  String
  content    String
  rating     Int?     // 1-5
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([authorId])
  @@index([isApproved])
  @@map("comments")
}

model PhotoRating {
  id        String   @id @default(cuid())
  userId    String
  photoId   String
  score     Int      // 1-5
  createdAt DateTime @default(now())

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo ProfilePhoto @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([userId, photoId])
  @@index([photoId])
  @@map("photo_ratings")
}

model Media {
  id          String   @id @default(cuid())
  url         String
  type        MediaType @default(IMAGE)
  isPremium   Boolean  @default(false)
  price       Int      @default(0)
  
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id])
  
  unlockedBy  UnlockedMedia[]
}

model UnlockedMedia {
  id        String   @id @default(cuid())
  userId    String
  mediaId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  media     Media    @relation(fields: [mediaId], references: [id])

  @@unique([userId, mediaId])
}

model Report {
  id          String   @id @default(cuid())
  reason      String
  details     String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  reporterId  String
  reporter    User     @relation("FiledReports", fields: [reporterId], references: [id])

  profileId   String
  profile     Profile  @relation("ReceivedReports", fields: [profileId], references: [id])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  credits     Int
  stripeId    String   @unique
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model ChatRoom {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  participants User[]
  messages     Message[]
}

model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id])
  
  senderId  String
  sender    User     @relation("UserMessages", fields: [senderId], references: [id])
  oldSender User?    @relation("MessageSender", fields: [oldSenderId], references: [id])
  oldSenderId String?
}

model Announcement {
  id        String   @id @default(cuid())
  authorId  String
  title     String
  content   String
  cityId    Int?
  category  String?
  views     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city City? @relation(fields: [cityId], references: [id])

  @@index([cityId])
  @@index([createdAt(sort: Desc)])
  @@map("announcements")
}

model Payment {
  id              String         @id @default(cuid())
  userId          String
  profileId       String?
  stripeSessionId String?        @unique
  stripePaymentId String?
  amount          Int            // centimes
  currency        String         @default("eur")
  product         PaymentProduct
  status          PaymentStatus  @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user    User     @relation(fields: [userId],   references: [id])
  profile Profile? @relation(fields: [profileId], references: [id])

  @@index([userId])
  @@index([profileId])
  @@index([status])
  @@map("payments")
}

model CityTour {
  id          String   @id @default(cuid())
  profileId   String
  cityId      Int
  dateFrom    DateTime
  dateTo      DateTime
  description String?
  createdAt   DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  city    City    @relation(fields: [cityId],    references: [id])

  @@index([profileId])
  @@index([cityId])
  @@index([dateFrom])
  @@map("city_tours")
}

model Availability {
  id        String   @id @default(cuid())
  profileId String
  dayOfWeek Int      // 0=Sun, 6=Sat
  startHour Int      // 0-23
  endHour   Int      // 0-23

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("availability")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── Compliance & Security (18 U.S.C. § 2257) ─────────────────────────

model KycRecord {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Encrypted data (AES-256-GCM)
  encryptedRealName String   @db.Text
  encryptedDob      String   @db.Text
  
  // Private S3 keys
  idDocumentS3Key   String
  selfieS3Key       String
  
  status            KycStatus @default(PENDING)
  verificationId    String?   
  
  verifiedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@map("kyc_records")
}

enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
  REQUIRES_MANUAL_REVIEW
}

model AuditLog {
  id          String   @id @default(cuid())
  adminId     String   
  action      String   
  targetId    String?  
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

// ─── Media Pipeline (Enterprise Queue) ──────────────────────────────

model MediaAsset {
  id               String   @id @default(cuid())
  profileId        String
  profile          Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  originalFilename String
  fileType         String   // "IMAGE" or "VIDEO"
  url              String?  // Final processed URL
  hlsPlaylistUrl   String?  // Adaptive streaming for video
  
  status           MediaStatus @default(PROCESSING)
  
  // Algorithmic Engagement & Ranking
  upvotes          Int      @default(0)
  downvotes        Int      @default(0)
  hotScore         Float    @default(0.0) 
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([profileId])
  @@index([status])
  @@map("media_assets")
}

enum MediaStatus {
  PROCESSING
  COMPLETED
  FAILED
  REJECTED_MODERATION
}

// ─── Internal Ledger (Credit History) ───────────────────────────────

model CreditLog {
  id          String         @id @default(cuid())
  userId      String
  amount      Int            // POSITIVE for received/purchased, NEGATIVE for spent
  type        CreditLogType
  description String?
  createdAt   DateTime       @default(now())

  user        User           @relation("UserCreditLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("credit_logs")
}

enum CreditLogType {
  PURCHASE
  BOOST
  CHAT
  REFUND
}

model Order {
  id             String      @id @default(cuid())
  userId         String
  amount         Float
  credits        Int
  status         String      @default("PENDING") // PENDING, COMPLETED, CANCELED
  cryptoCurrency String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user           User        @relation("UserOrders", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("orders")
}

model CallSession {
  id              String   @id @default(cuid())
  roomId          String   @unique
  
  clientId        String
  client          User     @relation("ClientCalls", fields: [clientId], references: [id])
  
  escortId        String
  escort          User     @relation("EscortCalls", fields: [escortId], references: [id])
  
  status          CallStatus @default(ONGOING)
  startTime       DateTime @default(now())
  endTime         DateTime?
  
  costPerMinute   Int
  totalBilled     Int      @default(0)
  escortEarnings  Int      @default(0)
}

enum CallStatus {
  ONGOING
  COMPLETED
  INSUFFICIENT_FUNDS
  CANCELLED
}